# =============================================================
# .dockerignore — Chest-Xpert Backend
# =============================================================
# Excludes files not needed in the Docker build context.
# Reduces build context size and prevents secrets from leaking.
# NOTE: models/ is NOT excluded — model is embedded in the image.
# =============================================================

# Virtual environment (rebuilt inside container)
.venv/
venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/

# Tests (not needed in production image)
tests/

# Scripts (dev tooling, not needed at runtime)
scripts/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Git metadata
.git/
.gitignore
.gitattributes

# Environment files (secrets injected at runtime, never baked in)
.env

# OS-specific files
.DS_Store
Thumbs.db

# Documentation (not needed in image)
*.md
LICENSE

# Distribution artifacts
dist/
*.egg-info/
