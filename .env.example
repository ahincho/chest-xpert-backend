# Chest-Xpert Backend Configuration
# Copy this file to .env and adjust values as needed.
# Environment variables take precedence over values defined here.

# Path to the ONNX model file (relative to the project root)
CHESTXPERT_MODEL_PATH=../chest-xpert-ai/models/chest-xpert-model.onnx

# Allowed CORS origins (JSON array format)
CHESTXPERT_CORS_ORIGINS=["http://localhost:4200"]

# Server port (1024–65535)
CHESTXPERT_SERVER_PORT=8000

# RGB-Diff filter threshold (0.0–255.0)
CHESTXPERT_RGB_DIFF_THRESHOLD=5.0

# Target pathology classes (JSON array format)
CHESTXPERT_TARGET_CLASSES=["Cardiomegaly","Edema","Consolidation","Atelectasis","Pleural Effusion"]

# ---------------------------------------------------------------------------
# Kaggle credentials (used by scripts/download_test_images.py)
# Get your token at: https://www.kaggle.com/settings → API → Create New Token
# ---------------------------------------------------------------------------
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Number of images to download per pathology class (default: 10)
KAGGLE_IMAGES_PER_CLASS=10
